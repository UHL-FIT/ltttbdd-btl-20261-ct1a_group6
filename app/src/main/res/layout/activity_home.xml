<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FCE4EC"
    tools:ignore="HardcodedText,MissingTranslation">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Phần Header -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="24dp">

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardAvatar"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    app:cardBackgroundColor="#F48FB1"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="SJ"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold" />
                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="12dp"
                    android:layout_toEndOf="@id/cardAvatar"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/txtUsername"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sarah Johnson"
                        android:textColor="#333333"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Chào buổi sáng"
                        android:textColor="#888888"
                        android:textSize="13sp" />
                </LinearLayout>

                <ImageButton
                    android:id="@+id/btnNotification"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@android:drawable/btn_default"
                    android:contentDescription="Thông báo"
                    android:src="@android:drawable/ic_popup_reminder" />
            </RelativeLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:text="Theo Dõi Tâm Trạng,\nThấu Hiểu Bản Thân."
                android:textColor="#212121"
                android:textSize="28sp"
                android:textStyle="bold" />

            <!-- Các Tab Hoạt động -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/tabActivity"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:backgroundTint="#E040FB"
                        android:text="Hoạt động"
                        android:textColor="#FFFFFF" />

                    <Button
                        android:id="@+id/tabMood"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:backgroundTint="#FFFFFF"
                        android:text="Tâm trạng"
                        android:textColor="#555555" />

                    <Button
                        android:id="@+id/tabFeed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:backgroundTint="#FFFFFF"
                        android:text="Bản tin"
                        android:textColor="#555555" />

                    <Button
                        android:id="@+id/tabSleep"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:backgroundTint="#FFFFFF"
                        android:text="Giấc ngủ"
                        android:textColor="#555555" />
                </LinearLayout>
            </HorizontalScrollView>

            <!-- Lịch sử tâm trạng -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="#FFF3F8"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Lịch sử tâm trạng"
                            android:textColor="#212121"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/txtViewAllHistory"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:padding="4dp"
                            android:text="Xem tất cả"
                            android:textColor="#888888" />
                    </RelativeLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/btnMon"
                            android:layout_width="52dp"
                            android:layout_height="60dp"
                            android:layout_marginEnd="6dp"
                            android:backgroundTint="#FF7043"
                            android:padding="0dp"
                            android:text="😡\nT2"
                            android:textColor="#FFFFFF"
                            android:textSize="11sp" />

                        <Button
                            android:id="@+id/btnTue"
                            android:layout_width="52dp"
                            android:layout_height="60dp"
                            android:layout_marginEnd="6dp"
                            android:backgroundTint="#FFAB91"
                            android:padding="0dp"
                            android:text="😰\nT3"
                            android:textColor="#FFFFFF"
                            android:textSize="11sp" />

                        <Button
                            android:id="@+id/btnWed"
                            android:layout_width="52dp"
                            android:layout_height="60dp"
                            android:layout_marginEnd="6dp"
                            android:backgroundTint="#00ACC1"
                            android:padding="0dp"
                            android:text="😷\nT4"
                            android:textColor="#FFFFFF"
                            android:textSize="11sp" />

                        <Button
                            android:id="@+id/btnThu"
                            android:layout_width="52dp"
                            android:layout_height="60dp"
                            android:layout_marginEnd="6dp"
                            android:backgroundTint="#F57C00"
                            android:padding="0dp"
                            android:text="😬\nT5"
                            android:textColor="#FFFFFF"
                            android:textSize="11sp" />

                        <Button
                            android:id="@+id/btnFri"
                            android:layout_width="52dp"
                            android:layout_height="60dp"
                            android:backgroundTint="#FBC02D"
                            android:padding="0dp"
                            android:text="😁\nT6"
                            android:textColor="#212121"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Kế hoạch hành động -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kế hoạch hành động"
                    android:textColor="#212121"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtViewAllAction"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:padding="4dp"
                    android:text="Xem tất cả"
                    android:textColor="#888888" />
            </RelativeLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:layout_marginBottom="24dp"
                android:orientation="horizontal">

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardMood"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="#FF8A65"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="😊 Tâm trạng"
                            android:textColor="#FFFFFF"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/txtMoodStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Buồn"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:id="@+id/layoutMoodChart"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="bottom|center_horizontal"
                            android:orientation="horizontal"
                            android:layout_marginTop="10dp">

                            <View
                                android:id="@+id/bar1"
                                android:layout_width="6dp"
                                android:layout_height="20dp"
                                android:layout_marginEnd="4dp"
                                android:background="#FFE0B2" />

                            <View
                                android:id="@+id/bar2"
                                android:layout_width="6dp"
                                android:layout_height="35dp"
                                android:layout_marginEnd="4dp"
                                android:background="#FFE0B2" />

                            <View
                                android:id="@+id/bar3"
                                android:layout_width="6dp"
                                android:layout_height="25dp"
                                android:layout_marginEnd="4dp"
                                android:background="#FFFFFF" />

                            <View
                                android:id="@+id/bar4"
                                android:layout_width="6dp"
                                android:layout_height="45dp"
                                android:layout_marginEnd="4dp"
                                android:background="#FFE0B2" />

                            <View
                                android:id="@+id/bar5"
                                android:layout_width="6dp"
                                android:layout_height="30dp"
                                android:background="#FFE0B2" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardScore"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    app:cardBackgroundColor="#7E57C2"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="start"
                            android:text="😊 Điểm Bản Tin"
                            android:textColor="#FFFFFF"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/txtScore"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="80"
                            android:textColor="#FFFFFF"
                            android:textSize="28sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/txtScoreStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Khỏe mạnh"
                            android:textColor="#B39DDB"
                            android:textSize="12sp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- Giờ Tâm Thức (Phần bị thiếu) -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Giờ Tâm Thức"
                    android:textColor="#212121"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtViewAllHours"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:padding="4dp"
                    android:text="Xem tất cả"
                    android:textColor="#888888" />
            </RelativeLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="#FFF3F8"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <Button
                        android:id="@+id/btnClockIcon"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:backgroundTint="#F8BBD0"
                        android:padding="0dp"
                        android:text="⏰" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="12dp"
                        android:layout_toEndOf="@id/btnClockIcon"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Giờ Chánh Niệm"
                            android:textColor="#333333"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/txtMindfulHours"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="3 Giờ"
                            android:textColor="#777777"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="12dp"
                        android:layout_toStartOf="@id/btnMoreOptions"
                        android:orientation="vertical"
                        android:gravity="end">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Giấc Ngủ"
                            android:textColor="#333333"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/txtSleepInfo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Chưa có"
                            android:textColor="#777777"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <ImageButton
                        android:id="@+id/btnMoreOptions"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:background="@android:color/transparent"
                        android:contentDescription="Tùy chọn khác"
                        android:src="@android:drawable/ic_menu_more" />
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- Nút bấm nổi để viết nhật ký -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabWriteDiary"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_margin="24dp"
        android:backgroundTint="#E91E63"
        android:contentDescription="Viết nhật ký"
        android:src="@android:drawable/ic_input_add"
        app:tint="#FFFFFF" />

</RelativeLayout>
